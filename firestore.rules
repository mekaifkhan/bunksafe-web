rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global catch-all default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper: Validates ID structure
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Users Collection rules
    // Documents are keyed by lowercase email.
    match /users/{email} {
      allow read, write: if true; // Lightweight sync based on email address
    }

    // Feature Requests rules
    match /featureRequests/{requestId} {
      allow create: if isValidId(requestId) &&
                    request.resource.data.keys().hasAll(['id', 'email', 'title', 'description', 'createdAt', 'status']) &&
                    request.resource.data.keys().size() == 6;
      allow read: if true;
    }

    // App Version configuration rules
    match /appConfig/version {
      allow read: if true;
      allow write: if false; // Only admin/backend should update, clients only read
    }

    // Changelog rules
    match /changelog/{changelogId} {
      allow read: if true;
      allow write: if false; // Clients only read changelogs
    }

    // Notification Devices rules
    match /notificationDevices/{deviceId} {
      allow get: if isValidId(deviceId);
      allow create, update: if isValidId(deviceId) &&
                            request.resource.data.keys().hasAll(['deviceId', 'fcmToken', 'notificationEnabled', 'todayAttendance', 'semesterActive', 'holidayToday', 'timezone', 'lastSync', 'lastReminderBypassDate']) &&
                            request.resource.data.keys().size() == 9 &&
                            request.resource.data.deviceId == deviceId &&
                            request.resource.data.deviceId is string &&
                            request.resource.data.fcmToken is string &&
                            request.resource.data.notificationEnabled is bool &&
                            request.resource.data.todayAttendance is bool &&
                            request.resource.data.semesterActive is bool &&
                            request.resource.data.holidayToday is bool &&
                            request.resource.data.timezone is string &&
                            request.resource.data.lastSync is string &&
                            request.resource.data.lastReminderBypassDate is string;
      allow delete: if false;
    }
  }
}
