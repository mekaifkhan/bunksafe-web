{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile configuration and statistics.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name of the student."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address of the student."
        },
        "college": {
          "type": "string",
          "description": "Name of the college."
        },
        "department": {
          "type": "string",
          "description": "Department or branch of the student."
        },
        "semester": {
          "type": "string",
          "description": "Current semester."
        },
        "mobile": {
          "type": "string",
          "description": "Contact number."
        },
        "avatar": {
          "type": "string",
          "description": "Profile picture URL or base64."
        },
        "registeredAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation/registration timestamp of the user profile."
        }
      },
      "required": ["name", "email", "college", "department", "semester"]
    },
    "FeatureRequest": {
      "title": "FeatureRequest",
      "description": "Feature request submitted by users.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique request ID."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Submitting user's email."
        },
        "title": {
          "type": "string",
          "description": "Brief title of the feature request."
        },
        "description": {
          "type": "string",
          "description": "Detailed description of the feature request."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Submission timestamp."
        },
        "status": {
          "type": "string",
          "description": "Current status of request (e.g., pending, planned, completed)."
        }
      },
      "required": ["id", "email", "title", "description", "createdAt", "status"]
    },
    "AppConfig": {
      "title": "AppConfig",
      "description": "Central app configuration such as latest version details.",
      "type": "object",
      "properties": {
        "latestVersion": {
          "type": "string",
          "description": "The latest published app version (e.g. 2.5.0)."
        },
        "downloadUrl": {
          "type": "string",
          "description": "URL to download the update."
        },
        "releasedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Release timestamp of the latest version."
        },
        "changelog": {
          "type": "array",
          "description": "Short release description array."
        }
      },
      "required": ["latestVersion", "downloadUrl", "releasedAt"]
    },
    "ChangelogItem": {
      "title": "ChangelogItem",
      "description": "Release history and changelog record.",
      "type": "object",
      "properties": {
        "version": {
          "type": "string",
          "description": "Version identifier (e.g. 2.4.0)."
        },
        "releaseDate": {
          "type": "string",
          "description": "Formatted date of the release."
        },
        "newFeatures": {
          "type": "array",
          "description": "List of new features added in this release."
        },
        "bugFixes": {
          "type": "array",
          "description": "List of bug fixes in this release."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when this changelog item was posted."
        }
      },
      "required": ["version", "releaseDate", "newFeatures", "bugFixes", "createdAt"]
    }
  },
  "firestore": {
    "/users/{email}": {
      "schema": "UserProfile",
      "description": "Core student profiles and settings indexed by lowercase email."
    },
    "/featureRequests/{requestId}": {
      "schema": "FeatureRequest",
      "description": "User-submitted feature requests stored globally in Firestore."
    },
    "/appConfig/version": {
      "schema": "AppConfig",
      "description": "Central versioning and updates information."
    },
    "/changelog/{changelogId}": {
      "schema": "ChangelogItem",
      "description": "Global list of changelogs and version release histories."
    }
  }
}
