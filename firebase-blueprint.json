{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile configuration and statistics.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name of the student."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address of the student."
        },
        "college": {
          "type": "string",
          "description": "Name of the college."
        },
        "department": {
          "type": "string",
          "description": "Department or branch of the student."
        },
        "semester": {
          "type": "string",
          "description": "Current semester."
        },
        "mobile": {
          "type": "string",
          "description": "Contact number."
        },
        "avatar": {
          "type": "string",
          "description": "Profile picture URL or base64."
        },
        "registeredAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation/registration timestamp of the user profile."
        }
      },
      "required": ["name", "email", "college", "department", "semester"]
    },
    "BaaChatSession": {
      "title": "BaaChatSession",
      "description": "A single BAA study assistant conversation session.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique session identifier."
        },
        "title": {
          "type": "string",
          "description": "Auto-generated or user-defined title of the conversation."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Session creation timestamp."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Session last-updated timestamp."
        },
        "messages": {
          "type": "array",
          "description": "List of messages exchanged in this session."
        }
      },
      "required": ["id", "title", "createdAt", "updatedAt", "messages"]
    }
  },
  "firestore": {
    "/users/{email}": {
      "schema": "UserProfile",
      "description": "Core student profiles and settings indexed by lowercase email."
    },
    "/users/{email}/baaChats/{chatId}": {
      "schema": "BaaChatSession",
      "description": "BAA AI study chat history sessions for a specific user."
    }
  }
}
